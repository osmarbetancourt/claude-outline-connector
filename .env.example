# Required — base URL of your Outline instance (no trailing slash)
OUTLINE_BASE_URL=https://outline.dreamit.software/

# Required — Outline API key (Outline → Settings → API → New token)
OUTLINE_API_KEY=ol_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — host and port the MCP server binds to inside the container
MCP_HOST=0.0.0.0
MCP_PORT=8765

# OAuth 2.1 — required for Claude.ai web connector (leave empty for local dev / no auth)
#
# MCP_SERVER_URL: public HTTPS URL of this server, used in OAuth discovery responses
# OAUTH_CLIENT_ID: any string you choose; enter the same value in Claude.ai's connector dialog
# OAUTH_CLIENT_SECRET: a strong random secret; enter the same value in Claude.ai's connector dialog
#
# Generate a secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_SERVER_URL=https://mcp.betancourtosmar.com/
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# github-mcp service (port 8766)
# ---------------------------------------------------------------------------

# Required — GitHub Personal Access Token
# Scopes needed: repo, workflow, read:org
# GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
TOKEN_GITHUB=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public HTTPS URL for the github-mcp server (different subdomain from outline-mcp)
GITHUB_MCP_SERVER_URL=https://mcp-gh.betancourtosmar.com

# OAuth 2.1 for the github-mcp connector (separate credentials from outline-mcp)
OAUTH_CLIENT_ID_GITHUB=
OAUTH_CLIENT_SECRET_GITHUB=
