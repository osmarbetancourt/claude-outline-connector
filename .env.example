# Required: Base URL of your Outline instance (no trailing slash)
OUTLINE_BASE_URL=https://wiki.example.com

# Required: Outline API key
# Create one at: https://your-outline/settings/tokens
OUTLINE_API_KEY=ol_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Host and port the MCP server listens on (defaults shown)
MCP_HOST=0.0.0.0
MCP_PORT=8000
